# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://username@localhost:5432/agent_chat_db

# ============================================
# JWT AUTHENTICATION (Multiple Keys)
# ============================================
ACCESS_TOKEN_SECRET_KEY=generate-using-python-secrets-token-hex-32
REFRESH_TOKEN_SECRET_KEY=generate-using-python-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# OPENAI API
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# EXTERNAL APIs (Optional)
# ============================================
TAVILY_API_KEY=your-tavily-api-key
WEATHER_API_KEY=your-weather-api-key
FINNHUB_API_KEY=your-finnhub-api-key

# ============================================
# SUPABASE (Temporary - will remove after migration)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
