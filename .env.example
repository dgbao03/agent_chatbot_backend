OPENAI_API_KEY={YOUR_OPENAI_API_KEY}

# LLM Models (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini
LLM_SECURITY_MODEL=gpt-4o-mini
LLM_SUMMARY_MODEL=gpt-4o-mini
LLM_TIMEOUT=300
LLM_SECURITY_TIMEOUT=30
LLM_SUMMARY_TIMEOUT=120

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/agent_chat_db

# JWT
ACCESS_TOKEN_SECRET_KEY={YOUR_ACCESS_TOKEN_SECRET_KEY}
ACCESS_TOKEN_EXPIRE_MINUTES=30

REFRESH_TOKEN_SECRET_KEY={YOUR_REFRESH_TOKEN_SECRET_KEY}
REFRESH_TOKEN_EXPIRE_DAYS=7

ALGORITHM=HS256

# Google OAuth
GOOGLE_CLIENT_ID={YOUR_GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET={YOUR_GOOGLE_CLIENT_SECRET}
GOOGLE_REDIRECT_URI={YOUR_GOOGLE_REDIRECT_URI}

# Frontend
FRONTEND_URL={YOUR_FRONTEND_URL}

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Cookie
COOKIE_SECURE=false

# SMTP
# Note: SMTP_USE_TLS is derived from SMTP_PORT (port 465 = TLS, port 587 = STARTTLS)
SMTP_HOST={YOUR_SMTP_HOST}
SMTP_PORT=587
SMTP_USER={YOUR_SMTP_USER}
SMTP_PASSWORD={YOUR_SMTP_PASSWORD}
SMTP_FROM_EMAIL={YOUR_SMTP_FROM_EMAIL}
SMTP_FROM_NAME={YOUR_SMTP_FROM_NAME}

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=both
LOG_FILE_PATH=logs/app.log
LOG_FILE_MAX_BYTES=52428800
LOG_FILE_BACKUP_COUNT=10

MEMORY_TOKEN_LIMIT=2000
MEMORY_KEEP_RATIO=0.2
PASSWORD_RESET_EXPIRE_MINUTES=15